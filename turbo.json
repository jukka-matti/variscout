{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/tsconfig*.json",
        "tsconfig*.json",
        "vite.config.*",
        "vitest.config.*",
        "$TURBO_ROOT$/vite.config.*",
        "$TURBO_ROOT$/vitest.config.*",
        "$TURBO_ROOT$/test/setup.ts",
        "$TURBO_ROOT$/config/**"
      ],
      "outputs": ["dist/**", ".astro/**"]
    },
    "@variscout/core#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/tsconfig*.json",
        "tsconfig*.json",
        "vite.config.*",
        "vitest.config.*",
        "$TURBO_ROOT$/vite.config.*",
        "$TURBO_ROOT$/vitest.config.*",
        "$TURBO_ROOT$/test/setup.ts",
        "$TURBO_ROOT$/config/**"
      ],
      "outputs": []
    },
    "@variscout/data#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/tsconfig*.json",
        "tsconfig*.json",
        "vite.config.*",
        "vitest.config.*",
        "$TURBO_ROOT$/vite.config.*",
        "$TURBO_ROOT$/vitest.config.*",
        "$TURBO_ROOT$/test/setup.ts",
        "$TURBO_ROOT$/config/**"
      ],
      "outputs": []
    },
    "@variscout/charts#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/tsconfig*.json",
        "tsconfig*.json",
        "vite.config.*",
        "vitest.config.*",
        "$TURBO_ROOT$/vite.config.*",
        "$TURBO_ROOT$/vitest.config.*",
        "$TURBO_ROOT$/test/setup.ts",
        "$TURBO_ROOT$/config/**"
      ],
      "outputs": []
    },
    "@variscout/stores#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/tsconfig*.json",
        "tsconfig*.json",
        "vite.config.*",
        "vitest.config.*",
        "$TURBO_ROOT$/vite.config.*",
        "$TURBO_ROOT$/vitest.config.*",
        "$TURBO_ROOT$/test/setup.ts",
        "$TURBO_ROOT$/config/**"
      ],
      "outputs": []
    },
    "@variscout/hooks#build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/tsconfig*.json",
        "tsconfig*.json",
        "vite.config.*",
        "vitest.config.*",
        "$TURBO_ROOT$/vite.config.*",
        "$TURBO_ROOT$/vitest.config.*",
        "$TURBO_ROOT$/test/setup.ts",
        "$TURBO_ROOT$/config/**"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/tsconfig*.json",
        "tsconfig*.json",
        "vite.config.*",
        "vitest.config.*",
        "$TURBO_ROOT$/vite.config.*",
        "$TURBO_ROOT$/vitest.config.*",
        "$TURBO_ROOT$/test/setup.ts",
        "$TURBO_ROOT$/config/**"
      ],
      "outputs": []
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.*",
        "eslint.config.*",
        "$TURBO_ROOT$/package.json",
        "$TURBO_ROOT$/pnpm-lock.yaml",
        "$TURBO_ROOT$/pnpm-workspace.yaml",
        "$TURBO_ROOT$/tsconfig*.json",
        "tsconfig*.json",
        "$TURBO_ROOT$/config/**"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
