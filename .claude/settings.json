{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TOOL_INPUT_file_path\" ] && pnpm exec ruflo hooks pre-edit --file \"$TOOL_INPUT_file_path\" 2>>/tmp/ruflo-hooks.log || true",
            "timeout": 1500
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TOOL_INPUT_command\" ] && pnpm exec ruflo hooks pre-command --command \"$TOOL_INPUT_command\" 2>>/tmp/ruflo-hooks.log || true",
            "timeout": 1500,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^Task$",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TOOL_INPUT_prompt\" ] && pnpm exec ruflo hooks pre-task --task-id \"task-$(date +%s)\" --description \"$TOOL_INPUT_prompt\" 2>>/tmp/ruflo-hooks.log || true",
            "timeout": 1500,
            "continueOnError": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TOOL_INPUT_file_path\" ] && pnpm exec ruflo hooks post-edit --file \"$TOOL_INPUT_file_path\" --success \"${TOOL_SUCCESS:-true}\" 2>>/tmp/ruflo-hooks.log || true",
            "timeout": 1500,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TOOL_INPUT_command\" ] && pnpm exec ruflo hooks post-command --command \"$TOOL_INPUT_command\" --success \"${TOOL_SUCCESS:-true}\" 2>>/tmp/ruflo-hooks.log || true",
            "timeout": 1500,
            "continueOnError": true
          }
        ]
      },
      {
        "matcher": "^Task$",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TOOL_RESULT_agent_id\" ] && pnpm exec ruflo hooks post-task --task-id \"$TOOL_RESULT_agent_id\" --success \"${TOOL_SUCCESS:-true}\" 2>>/tmp/ruflo-hooks.log || true",
            "timeout": 1500,
            "continueOnError": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$PROMPT\" ] && pnpm exec ruflo hooks route --task \"$PROMPT\" || true",
            "timeout": 1500,
            "continueOnError": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm exec ruflo daemon start --quiet 2>>/tmp/ruflo-hooks.log || true",
            "timeout": 5000,
            "continueOnError": true
          },
          {
            "type": "command",
            "command": "[ -n \"$SESSION_ID\" ] && pnpm exec ruflo hooks session-restore --session-id \"$SESSION_ID\" 2>>/tmp/ruflo-hooks.log || true",
            "timeout": 10000,
            "continueOnError": true
          },
          {
            "type": "command",
            "command": "bash scripts/check-git-hygiene.sh || true",
            "timeout": 3000,
            "continueOnError": true
          },
          {
            "type": "command",
            "command": "bash scripts/check-memory-pr-staleness.sh || true",
            "timeout": 5000,
            "continueOnError": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SESSION_ID\" ] && pnpm exec ruflo hooks session-end --session-id \"$SESSION_ID\" 2>>/tmp/ruflo-hooks.log || true",
            "timeout": 1500,
            "continueOnError": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node tools/statusline.cjs 2>/dev/null || echo \"▊ VariScout\"",
    "refreshMs": 5000,
    "enabled": true
  },
  "permissions": {
    "allow": [
      "Bash(npx ruflo:*)",
      "mcp__claude-flow__:*",
      "mcp__ruflo__:*"
    ],
    "deny": []
  },
  "attribution": {
    "commit": "Co-Authored-By: ruflo <ruv@ruv.net>",
    "pr": "🤖 Generated with [ruflo](https://github.com/ruvnet/ruflo)"
  }
}
