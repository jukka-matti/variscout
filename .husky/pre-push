#!/usr/bin/env bash
# pre-push — two responsibilities:
#   1. Blocking: run slow doc-graph checks (docs:check, check-dead-links.sh)
#      demoted from pre-commit. Either failure aborts the push.
#   2. Non-blocking: warn if pushing product code directly to main.
#
# Git supplies ref updates on stdin, one per line:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
#
# We only warn when <remote-ref> is refs/heads/main. Feature-branch
# pushes are untouched. User decides whether to heed the warning.

set -u
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# --- Blocking doc-graph checks (demoted from pre-commit) ---
# Run pnpm docs:check locally to iterate without re-pushing.
echo "pre-push: running docs:check (may take ~3 min)…"
pnpm docs:check || { echo "pre-push: docs:check failed — run 'pnpm docs:check' to diagnose." >&2; exit 1; }

echo "pre-push: running check-dead-links.sh…"
bash "$ROOT/scripts/check-dead-links.sh" || { echo "pre-push: check-dead-links.sh failed — fix broken links and retry." >&2; exit 1; }

# --- Non-blocking direct-to-main warning ---
while read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "$remote_ref" ] && continue
  [ "$remote_ref" != "refs/heads/main" ] && continue
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  # Collect the file list from the commits being pushed.
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    range="$local_sha"
    files=$(git show --name-only --format= "$local_sha" 2>/dev/null)
  else
    range="${remote_sha}..${local_sha}"
    files=$(git diff --name-only "$range" 2>/dev/null)
  fi
  [ -z "$files" ] && continue

  classification=$(echo "$files" | bash "$ROOT/scripts/classify-change.sh")

  case "$classification" in
    product|mixed)
      echo "⚠ pre-push: direct push to main contains $classification changes." >&2
      echo "  Files:" >&2
      echo "$files" | sed 's/^/    /' >&2
      echo "  Consider: feature branch → PR → bash scripts/pr-ready-check.sh → merge." >&2
      echo "  Proceeding anyway (warning is non-blocking)." >&2
      ;;
  esac
done

exit 0
