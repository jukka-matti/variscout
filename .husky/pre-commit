# Fast checks only on code-only commits (<5s). When docs/CLAUDE.md/packages/*/src/index.ts
# are staged, an incremental doc-graph check (check-diagram-health.sh --incremental) plus
# check-dead-links.sh run here so orphans/broken links are caught at commit time.
# Pre-push runs the full pnpm docs:check + check-dead-links.sh unconditionally.

npx lint-staged --concurrent false

# SSOT check — warn if CLAUDE.md sections duplicate content across files
bash scripts/check-ssot.sh

# ADR-074 level-spanning-surface boundary check
bash scripts/check-level-boundaries.sh

# CLAUDE.md size check — fail if >120% of per-file budget
bash scripts/check-claude-md-size.sh

# Decision-log reminder — warning-only, never blocks
bash scripts/decision-log-reminder.sh

# Docs-touched short-circuit: run incremental doc-graph checks only when a staged
# path is a doc-graph input (docs/**/*.md, CLAUDE.md, **/CLAUDE.md,
# packages/*/src/index.ts).  Code-only commits skip this block entirely.
# Pre-push still runs the full check (pnpm docs:check) unconditionally.
DOCS_PATTERN='^(docs/.*\.md$|CLAUDE\.md$|.*/CLAUDE\.md$|packages/[^/]+/src/index\.ts$)'
STAGED_DOCS=$(git diff --cached --name-only | grep -E "$DOCS_PATTERN" || true)
if [ -n "$STAGED_DOCS" ]; then
  echo "docs touched — running incremental doc-graph check (~5s)" >&2
  # shellcheck disable=SC2086
  bash scripts/check-diagram-health.sh --incremental $STAGED_DOCS || exit 1
  bash scripts/check-dead-links.sh || exit 1
fi
