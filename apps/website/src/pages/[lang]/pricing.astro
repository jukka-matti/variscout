---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PricingCard from "../../components/PricingCard.astro";
import PricingFAQ from "../../components/PricingFAQ.astro";
import { ShieldCheck, Zap, FileText, Lock, ArrowRight } from "lucide-astro";
import { ui } from "../../i18n/ui";
import { getLangFromUrl } from "../../i18n/utils";

export function getStaticPaths() {
  const languages = Object.keys(ui);
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);

const pricingTiers = [
	{
		name: "Free Workspace",
		price: "€0",
		period: "forever",
		description: "Session-only analysis workspace for quality professionals",
		features: [
			"Full in-session analysis loop",
			"I-Chart, Boxplot, Pareto, Capability",
			"ANOVA",
			"20 sample datasets included",
			"Copy-paste from Excel",
			"Works offline after first visit",
		],
		limitations: [
			"Session-only (no save)",
			"Branding on charts",
			"Copy-paste input only",
		],
		cta: { text: "Try Free", href: "/app" },
		ctaNote: "No signup required",
	},
	{
		name: "Paid Workspace",
		price: "Planned",
		period: "individual + company",
		description: "Artifact layer for keeping, sharing, and consulting on work",
		features: [
			"Everything in Free Workspace, plus:",
			"File upload (CSV, Excel)",
			".vrs snapshot save/import",
			"Analysis Pack export",
			"Consultation Pack workflow",
			"Typed CoScout with channel-specific provider boundary",
			"No branding on charts",
		],
		cta: { text: "Enterprise & IT Details", href: `/${lang}/product/enterprise` },
		ctaNote: "Commerce integration is not live",
		whereToGet: "Individual and company channels",
		highlight: true,
		badge: "Artifact Layer",
	},
];

const faqs = [
	{
		question: "What can I do for free?",
		answer: "The Free Workspace gives you the full in-session analysis loop with core tools (I-Chart, Boxplot, Pareto, Capability, ANOVA), sample datasets, and copy-paste input. No signup required — just open it and start analyzing.",
	},
	{
		question: "What will paid channels add?",
		answer: "Paid channels add the artifact layer: .vrs save/import, Analysis and Consultation Pack export, file upload, no chart branding, and typed CoScout behind an individual or company provider boundary.",
	},
	{
		question: "Where does my data go?",
		answer: "VaRiScout processes data in your browser. Paid work is kept as local artifacts such as .vrs snapshots and exported packs; the company server is for tenant-governed access and CoScout plumbing, not document storage.",
	},
	{
		question: "Can I use VaRiScout for training?",
		answer: "Yes! The Web App is specifically designed for training and education. It includes 20 sample datasets covering real-world scenarios, works offline after the first visit, and requires no signup. Perfect for Green Belt training, university courses, and self-study.",
	},
	{
		question: "When will production commerce be available?",
		answer: "The local-first Workspace architecture is being converged first. Production Paddle and Azure Marketplace entitlement are separate follow-up work after the app boundary is stable.",
	},
];

const trustBadges = [
	{ icon: ShieldCheck, text: "No signup required" },
	{ icon: Zap, text: "Instant access" },
	{ icon: FileText, text: "Paid artifacts planned" },
	{ icon: Lock, text: "Your data stays yours" },
];
---

<BaseLayout
	title="VaRiScout Pricing | Free Workspace + Paid Artifact Layer"
	description="VaRiScout pricing direction: Free Workspace for in-session analysis, paid individual and company channels for .vrs, packs, and CoScout."
>
	<section class="py-20 bg-white border-b border-neutral-200">
		<div class="container-wide text-center">
			<h1 class="text-4xl md:text-5xl font-bold mb-6">Simple pricing. <span class="text-brand-primary">Start free.</span></h1>
			<p class="text-xl text-neutral-600 max-w-2xl mx-auto mb-16 italic">
				Try the local-first Workspace free. Paid channels will add the artifact layer for keeping, sharing, and consulting on work.
			</p>

			<div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto text-left">
				{pricingTiers.map((tier) => <PricingCard {...tier} />)}
			</div>

			<div class="text-center mt-8 space-y-3">
				<a href={`/${lang}/product/enterprise`} class="inline-flex items-center gap-2 text-brand-primary font-medium hover:gap-3 transition-all text-sm">
					See enterprise & IT details <ArrowRight size={16} />
				</a>
				<br />
				<a href={`/${lang}/getting-started`} class="inline-flex items-center gap-2 text-neutral-500 hover:text-brand-primary font-medium hover:gap-3 transition-all text-sm">
					View company preview guide <ArrowRight size={16} />
				</a>
			</div>

			<p class="text-center text-sm text-neutral-500 mt-4 italic">
				Production Paddle and Azure Marketplace entitlement are planned follow-up work, not live checkout surfaces.
			</p>
		</div>
	</section>

	<!-- Trust Badges -->
	<section class="py-12 bg-neutral-50 border-b border-neutral-200">
		<div class="container-wide">
			<div class="flex flex-wrap items-center justify-center gap-8 md:gap-16">
				{trustBadges.map((badge) => (
					<div class="flex items-center gap-3 text-neutral-600 grayscale opacity-80">
						<badge.icon size={20} aria-hidden="true" />
						<span class="text-sm font-medium italic">{badge.text}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section class="py-24 bg-white">
		<div class="container-wide">
			<h2 class="text-3xl font-bold text-center mb-16">Pricing FAQ</h2>
			<PricingFAQ items={faqs} />
		</div>
	</section>

	<!-- Privacy Callout -->
	<section class="py-20 bg-brand-secondary text-white">
		<div class="container-wide">
			<div class="flex flex-col md:flex-row items-center gap-12 bg-white/5 p-12 rounded-3xl border border-white/10">
				<div class="p-4 bg-brand-primary rounded-2xl text-white shadow-2xl shadow-brand-primary/20">
					<ShieldCheck size={48} />
				</div>
				<div class="flex-1 text-center md:text-left">
					<h2 class="text-2xl font-bold mb-4">Your Data Stays Yours</h2>
					<p class="text-neutral-400 max-w-2xl italic">
						VaRiScout is designed for sensitive operational data. Analysis runs in your browser; paid artifacts stay under your control as files and packs.
					</p>
				</div>
				<div>
					<a href="/app" class="btn btn-primary px-8 py-3 whitespace-nowrap">Open VaRiScout</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
