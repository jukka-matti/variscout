{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@variscout/core": ["../../packages/core/src"],
      "@variscout/core/*": ["../../packages/core/src/*"],
      "@variscout/hooks": ["../../packages/hooks/src"],
      "@variscout/hooks/*": ["../../packages/hooks/src/*"],
      "@variscout/ui": ["../../packages/ui/src"],
      "@variscout/ui/*": ["../../packages/ui/src/*"],
      "@variscout/charts": ["../../packages/charts/src"],
      "@variscout/charts/*": ["../../packages/charts/src/*"],
      "@variscout/data": ["../../packages/data/src"],
      "@variscout/data/*": ["../../packages/data/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
