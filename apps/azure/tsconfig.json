{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["@testing-library/jest-dom/vitest"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@variscout/core": ["../../packages/core/src"],
      "@variscout/core/*": ["../../packages/core/src/*"],
      "@variscout/hooks": ["../../packages/hooks/src"],
      "@variscout/hooks/*": ["../../packages/hooks/src/*"],
      "@variscout/ui": ["../../packages/ui/src"],
      "@variscout/ui/*": ["../../packages/ui/src/*"],
      "@variscout/charts": ["../../packages/charts/src"],
      "@variscout/charts/*": ["../../packages/charts/src/*"],
      "@variscout/data": ["../../packages/data/src"],
      "@variscout/data/*": ["../../packages/data/src/*"]
    }
  },
  "include": ["src", "server.d.ts"],
  "exclude": ["src/__tests__/server.integration.test.ts"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
