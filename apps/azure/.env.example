# VariScout Azure App — Environment Variables
#
# Authentication is handled by EasyAuth (App Service Authentication).
# No client-side auth config needed — the platform manages Azure AD login,
# token refresh, and consent automatically.

# License Tier (Azure Managed Application)
# Azure Marketplace deployments are always 'enterprise' (single plan, all features)
VITE_LICENSE_TIER=enterprise

# Marketplace Plan — controls feature gating
# 'standard' = €79/month (local files, AI included, User.Read only)
# 'team'     = €199/month (+ Blob Storage cloud sync, Knowledge Base)
# Default: 'standard' (set by ARM template parameter)
# VITE_VARISCOUT_PLAN=standard

# EasyAuth Notes:
#
# When deployed to Azure App Service, EasyAuth is configured via:
#   App Service > Authentication > Add identity provider > Microsoft
#
# Required API permissions (configured in the App Registration):
#   - Microsoft Graph > User.Read (Delegated) — get user profile
#   - Microsoft Graph > People.Read (Delegated) — people search (Team plan)
#   No admin-consent permissions required (ADR-059).
#
# The ARM template (infra/mainTemplate.json) configures EasyAuth automatically
# during Marketplace deployment. No manual setup needed for customers.

# Blob Storage (Team plan cloud sync)
# In production: STORAGE_ACCOUNT_NAME is set by the ARM template.
# The App Service managed identity has Storage Blob Data Contributor RBAC.
#
# For local development, use one of these options:
#
# Option A: Azurite local emulator (run `npx azurite-blob` in another terminal)
# LOCAL_DEV=true
# STORAGE_ACCOUNT_NAME=devstoreaccount1
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1
#
# Option B: Real Azure Storage Account
# STORAGE_ACCOUNT_NAME=your-storage-account
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Azure AI Search (Knowledge Base — Preview, currently disabled per ADR-059)
# VITE_AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
VITE_AI_SEARCH_INDEX=findings

# Local Development:
#   EasyAuth endpoints (/.auth/me, /.auth/login/aad) are not available locally.
#   The easyAuth.ts helper detects localhost and returns mock user data so the
#   app runs without Azure.
#   Set LOCAL_DEV=true to skip EasyAuth validation on /api/storage-token.
