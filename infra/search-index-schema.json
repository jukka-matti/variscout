    { "name": "text", "type": "Edm.String", "searchable": true },
    { "name": "factor", "type": "Edm.String", "filterable": true, "facetable": true },
    { "name": "status", "type": "Edm.String", "filterable": true, "facetable": true },
    { "name": "tag", "type": "Edm.String", "filterable": true },
    { "name": "eta_squared", "type": "Edm.Double", "sortable": true, "filterable": true },
    { "name": "cpk_before", "type": "Edm.Double", "sortable": true },
    { "name": "cpk_after", "type": "Edm.Double", "sortable": true },
    { "name": "suspected_cause", "type": "Edm.String", "searchable": true },
