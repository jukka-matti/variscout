{
  "analyzers": {
    "core": {
      "rules": {
        "use-recent-api-versions": {
          "level": "warning",
          "maxAllowedAgeInDays": 730
        },
        "no-hardcoded-location": {
          "level": "warning"
        },
        "no-loc-expr-outside-params": {
          "level": "warning"
        },
        "use-resource-id-functions": {
          "level": "warning"
        }
      }
    }
  }
}
