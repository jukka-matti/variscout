                "description": "Name for the AI Search service"
              }
            },
            "variscoutPlan": {
              "type": "string",
              "metadata": {
                "description": "VariScout plan identifier"
              }
            }
          },
          "variables": {
            "tags": {
              "product": "VariScout",
              "plan": "[parameters('variscoutPlan')]"
            }
          },
          "resources": [
            {
              "type": "Microsoft.Search/searchServices",
              "apiVersion": "2025-05-01",
              "name": "[parameters('searchServiceName')]",
              "location": "[parameters('location')]",
              "tags": "[variables('tags')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "sku": {
                "name": "basic"
              },
              "properties": {
                "replicaCount": 1,
                "partitionCount": 1,
                "hostingMode": "Default",
                "semanticSearch": "standard",
                "publicNetworkAccess": "Enabled",
                "authOptions": {
                  "aadOrApiKey": {
                    "aadAuthFailureMode": "http401WithBearerChallenge"
                  }
                },
                "networkRuleSet": {
                  "bypass": "AzureServices"
                }
              }
            }
          ],
          "outputs": {
            "searchServiceId": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the Search service"
              },
              "value": "[resourceId('Microsoft.Search/searchServices', parameters('searchServiceName'))]"
            },
            "searchAdminKey": {
              "type": "string",
              "metadata": {
                "description": "Admin key for the Search service"
              },
              "value": "[listAdminKeys(resourceId('Microsoft.Search/searchServices', parameters('searchServiceName')), '2025-05-01').primaryKey]"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "appService",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "appServicePlanName": {
            "value": "[variables('appServicePlanName')]"
          },
          "webAppName": {
            "value": "[variables('webAppName')]"
          },
          "variscoutPlan": {
            "value": "[parameters('variscoutPlan')]"
          },
          "clientId": {
            "value": "[parameters('clientId')]"
          },
          "clientSecret": {
            "value": "[parameters('clientSecret')]"
          },
          "packageUrl": {
            "value": "[parameters('packageUrl')]"
          },
          "hasAI": {
            "value": "[variables('hasAI')]"
          },
          "hasTeamFeatures": {
            "value": "[variables('hasTeamFeatures')]"
          },
          "functionAppName": {
            "value": "[variables('functionAppName')]"
          },
          "aiEndpoint": "[if(variables('hasAI'), createObject('value', reference(resourceId('Microsoft.Resources/deployments', 'aiServices'), '2025-04-01').outputs.aiEndpoint.value), createObject('value', ''))]",
          "appInsightsConnectionString": "[if(variables('hasAI'), createObject('value', reference(resourceId('Microsoft.Resources/deployments', 'aiServices'), '2025-04-01').outputs.appInsightsConnectionString.value), createObject('value', ''))]",
          "searchServiceName": {
            "value": "[variables('searchServiceName')]"
          },
          "aiSearchIndex": {
            "value": "[variables('aiSearchIndex')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.40.2.10011",
              "templateHash": "14785674350473375142"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for deployment"
              }
            },
            "appServicePlanName": {
              "type": "string",
              "metadata": {
                "description": "Name for the App Service Plan"
              }
            },
            "webAppName": {
              "type": "string",
              "metadata": {
                "description": "Name for the Web App"
              }
            },
            "variscoutPlan": {
              "type": "string",
              "metadata": {
                "description": "VariScout plan identifier"
              }
            },
            "clientId": {
              "type": "string",
              "metadata": {
                "description": "Client ID of the Azure AD App Registration"
              }
            },
            "clientSecret": {
              "type": "securestring",
              "metadata": {
                "description": "Client secret of the Azure AD App Registration"
              }
            },
            "packageUrl": {
              "type": "string",
              "metadata": {
                "description": "URL to the VariScout application deployment package"
              }
            },
            "hasAI": {
              "type": "bool",
              "metadata": {
                "description": "Whether AI features are enabled"
              }
            },
            "hasTeamFeatures": {
              "type": "bool",
              "metadata": {
                "description": "Whether Team plan features are enabled"
              }
            },
            "functionAppName": {
              "type": "string",
              "metadata": {
                "description": "Function App name (for URL construction)"
              }
            },
            "aiEndpoint": {
              "type": "string",
              "metadata": {
                "description": "AI endpoint URL (empty if AI disabled)"
              }
            },
            "appInsightsConnectionString": {
              "type": "string",
              "metadata": {
                "description": "App Insights connection string (empty if AI disabled)"
              }
            },
            "searchServiceName": {
              "type": "string",
              "metadata": {
                "description": "Search service name (for URL construction)"
              }
            },
            "aiSearchIndex": {
              "type": "string",
              "metadata": {
                "description": "AI Search index name"
              }
            }
          },
          "variables": {
            "tags": {
              "product": "VariScout",
              "plan": "[parameters('variscoutPlan')]",
              "managedBy": "AzureMarketplace"
            }
          },
          "resources": [
            {
              "type": "Microsoft.Web/serverfarms",
              "apiVersion": "2024-04-01",
              "name": "[parameters('appServicePlanName')]",
              "location": "[parameters('location')]",
              "tags": "[variables('tags')]",
              "kind": "linux",
              "sku": {
                "name": "B1",
                "tier": "Basic"
              },
              "properties": {
                "reserved": true
              }
            },
            {
              "type": "Microsoft.Web/sites",
              "apiVersion": "2024-04-01",
              "name": "[parameters('webAppName')]",
              "location": "[parameters('location')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "tags": "[variables('tags')]",
              "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]",
                "httpsOnly": true,
                "siteConfig": {
                  "linuxFxVersion": "NODE|22-lts",
                  "appSettings": [
                    {
                      "name": "WEBSITE_RUN_FROM_PACKAGE",
                      "value": "[parameters('packageUrl')]"
                    },
                    {
                      "name": "VITE_LICENSE_TIER",
                      "value": "enterprise"
                    },
                    {
                      "name": "MICROSOFT_PROVIDER_AUTHENTICATION_SECRET",
                      "value": "[parameters('clientSecret')]"
                    },
                    {
                      "name": "VITE_VARISCOUT_PLAN",
                      "value": "[parameters('variscoutPlan')]"
                    },
                    {
                      "name": "VITE_FUNCTION_URL",
                      "value": "[if(parameters('hasAI'), format('https://{0}.azurewebsites.net', parameters('functionAppName')), '')]"
                    },
                    {
                      "name": "AI_ENDPOINT",
                      "value": "[parameters('aiEndpoint')]"
                    },
                    {
                      "name": "AI_SEARCH_ENDPOINT",
                      "value": "[if(parameters('hasTeamFeatures'), format('https://{0}.search.windows.net', parameters('searchServiceName')), '')]"
                    },
                    {
                      "name": "AI_SEARCH_INDEX",
                      "value": "[parameters('aiSearchIndex')]"
                    },
                    {
                      "name": "FUNCTION_URL",
                      "value": "[if(parameters('hasAI'), format('https://{0}.azurewebsites.net', parameters('functionAppName')), '')]"
                    },
                    {
                      "name": "VITE_APPINSIGHTS_CONNECTION_STRING",
                      "value": "[parameters('appInsightsConnectionString')]"
                    }
                  ],
                  "minTlsVersion": "1.2",
                  "ftpsState": "Disabled"
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', parameters('appServicePlanName'))]"
              ]
            },
            {
              "type": "Microsoft.Web/sites/config",
              "apiVersion": "2024-04-01",
              "name": "[format('{0}/{1}', parameters('webAppName'), 'authsettingsV2')]",
              "properties": {
                "platform": {
                  "enabled": true
                },
                "globalValidation": {
                  "requireAuthentication": true,
                  "unauthenticatedClientAction": "RedirectToLoginPage",
                  "redirectToProvider": "azureactivedirectory",
                  "excludedPaths": ["/health", "/config"]
                },
                "identityProviders": {
                  "azureActiveDirectory": {
                    "enabled": true,
                    "registration": {
                      "openIdIssuer": "[format('https://login.microsoftonline.com/{0}/v2.0', subscription().tenantId)]",
                      "clientId": "[parameters('clientId')]",
                      "clientSecretSettingName": "MICROSOFT_PROVIDER_AUTHENTICATION_SECRET"
                    },
                    "login": {
                      "loginParameters": [
                        "[if(parameters('hasTeamFeatures'), 'scope=openid profile email User.Read Files.ReadWrite Files.ReadWrite.All Channel.ReadBasic.All People.Read ChannelMessage.Send', 'scope=openid profile email User.Read https://cognitiveservices.azure.com/.default')]"
                      ]
                    }
                  }
                },
                "login": {
                  "tokenStore": {
                    "enabled": true
                  }
                }
              },
              "dependsOn": ["[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"]
            }
          ],
          "outputs": {
            "webAppId": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the Web App"
              },
              "value": "[resourceId('Microsoft.Web/sites', parameters('webAppName'))]"
            },
            "defaultHostName": {
              "type": "string",
              "metadata": {
                "description": "Default hostname of the Web App"
