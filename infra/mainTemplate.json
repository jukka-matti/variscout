{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "1248603464213203570"
    },
    "description": "Deploys VariScout Azure App as a Managed Application with App Service and EasyAuth"
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for deployment"
      }
    },
    "appName": {
      "type": "string",
      "defaultValue": "[format('variscout-{0}', uniqueString(resourceGroup().id))]",
      "minLength": 3,
      "maxLength": 24,
      "metadata": {
        "description": "Name for the App Service (3-24 lowercase letters, numbers, or hyphens)"
      }
    },
    "clientId": {
      "type": "string",
      "metadata": {
        "description": "Client ID of the Azure AD App Registration for authentication"
      }
    },
    "clientSecret": {
      "type": "securestring",
      "metadata": {
        "description": "Client secret of the Azure AD App Registration. Stored in Key Vault and referenced via @Microsoft.KeyVault() in app settings."
      }
    },
    "packageUrl": {
      "type": "string",
      "defaultValue": "[format('https://variscout.blob.{0}/releases/variscout-azure-latest.zip', environment().suffixes.storage)]",
      "metadata": {
        "description": "URL to the VariScout application deployment package"
      }
    },
    "variscoutPlan": {
      "type": "string",
      "defaultValue": "standard",
      "allowedValues": ["standard", "team"],
      "metadata": {
        "description": "VariScout plan: 'standard' (local files, AI included), 'team' (+ Blob Storage cloud sync)"
      }
    }
  },
  "variables": {
    "appServicePlanName": "[format('{0}-plan', parameters('appName'))]",
    "webAppName": "[parameters('appName')]",
    "appInsightsName": "[format('{0}-insights', parameters('appName'))]",
    "aiServicesName": "[format('{0}-ai', parameters('appName'))]",
    "searchServiceName": "[format('{0}-search', parameters('appName'))]",
    "keyVaultName": "[format('kv-{0}-{1}', take(parameters('appName'), 17), take(uniqueString(resourceGroup().id), 4))]",
    "hasTeamFeatures": "[equals(parameters('variscoutPlan'), 'team')]",
    "hasAI": "[not(equals(parameters('variscoutPlan'), 'free'))]",
    "aiSearchIndex": "findings"
  },
  "resources": [
    {
      "condition": "[variables('hasAI')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "aiServices",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "location": {
            "value": "[parameters('location')]"
          },
          "aiServicesName": {
            "value": "[variables('aiServicesName')]"
          },
          "appInsightsName": {
            "value": "[variables('appInsightsName')]"
          },
          "variscoutPlan": {
            "value": "[parameters('variscoutPlan')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "4198521691278681829"
            }
          },
          "parameters": {
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region for deployment"
              }
            },
            "aiServicesName": {
              "type": "string",
              "metadata": {
                "description": "Name for the OpenAI account"
              }
            },
            "appInsightsName": {
              "type": "string",
              "metadata": {
                "description": "Name for the App Insights resource"
              }
            },
            "variscoutPlan": {
              "type": "string",
              "metadata": {
                "description": "VariScout plan identifier"
              }
            }
          },
          "variables": {
            "tags": {
              "product": "VariScout",
              "plan": "[parameters('variscoutPlan')]"
            },
            "tagsWithManaged": "[union(variables('tags'), createObject('managedBy', 'AzureMarketplace'))]"
          },
          "resources": [
            {
              "type": "Microsoft.Insights/components",
              "apiVersion": "2020-02-02",
              "name": "[parameters('appInsightsName')]",
              "location": "[parameters('location')]",
              "tags": "[variables('tagsWithManaged')]",
              "kind": "web",
              "properties": {
                "Application_Type": "web",
                "RetentionInDays": 90,
                "publicNetworkAccessForIngestion": "Enabled",
                "publicNetworkAccessForQuery": "Enabled"
              }
            },
            {
              "type": "Microsoft.CognitiveServices/accounts",
              "apiVersion": "2025-09-01",
              "name": "[parameters('aiServicesName')]",
              "location": "[parameters('location')]",
              "tags": "[variables('tags')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "kind": "OpenAI",
              "sku": {
                "name": "S0"
              },
              "properties": {
                "customSubDomainName": "[parameters('aiServicesName')]",
                "publicNetworkAccess": "Enabled",
                "networkAcls": {
                  "defaultAction": "Allow"
                }
              }
            },
            {
              "type": "Microsoft.CognitiveServices/accounts/deployments",
              "apiVersion": "2025-09-01",
              "name": "[format('{0}/{1}', parameters('aiServicesName'), 'fast')]",
              "sku": {
                "name": "Standard",
                "capacity": 30
              },
              "properties": {
                "model": {
                  "format": "OpenAI",
                  "name": "gpt-5.4-nano",
                  "version": "2026-03-17"
                },
                "versionUpgradeOption": "OnceCurrentVersionExpired",
                "raiPolicyName": "Microsoft.DefaultV2"
              },
              "dependsOn": [
                "[resourceId('Microsoft.CognitiveServices/accounts', parameters('aiServicesName'))]"
              ]
            },
            {
              "type": "Microsoft.CognitiveServices/accounts/deployments",
              "apiVersion": "2025-09-01",
              "name": "[format('{0}/{1}', parameters('aiServicesName'), 'reasoning')]",
              "sku": {
                "name": "Standard",
                "capacity": 60
              },
              "properties": {
                "model": {
                  "format": "OpenAI",
                  "name": "gpt-5.4-mini",
                  "version": "2026-03-17"
                },
                "versionUpgradeOption": "OnceCurrentVersionExpired",
                "raiPolicyName": "Microsoft.DefaultV2"
              },
              "dependsOn": [
                "[resourceId('Microsoft.CognitiveServices/accounts', parameters('aiServicesName'))]",
                "[resourceId('Microsoft.CognitiveServices/accounts/deployments', parameters('aiServicesName'), 'fast')]"
              ]
            }
          ],
          "outputs": {
            "aiServicesId": {
              "type": "string",
              "metadata": {
                "description": "Resource ID of the OpenAI account"
              },
              "value": "[resourceId('Microsoft.CognitiveServices/accounts', parameters('aiServicesName'))]"
            },
            "aiEndpoint": {
              "type": "string",
              "metadata": {
                "description": "OpenAI endpoint URL"
              },
              "value": "[reference(resourceId('Microsoft.CognitiveServices/accounts', parameters('aiServicesName')), '2025-09-01').endpoint]"
            },
            "aiServicesApiKey": {
              "type": "string",
              "metadata": {
                "description": "API key for the OpenAI account"
              },
              "value": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', parameters('aiServicesName')), '2025-09-01').key1]"
            },
            "appInsightsConnectionString": {
              "type": "string",
              "metadata": {
                "description": "App Insights connection string"
              },
              "value": "[reference(resourceId('Microsoft.Insights/components', parameters('appInsightsName')), '2020-02-02').ConnectionString]"
            }
          }
        }
      }
    },
    {
      "condition": "[variables('hasTeamFeatures')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "search",
      "properties": {
        "expressionEvaluationOptions": {
