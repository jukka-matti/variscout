          },
          "aiEndpoint": "[if(variables('hasAI'), createObject('value', reference(resourceId('Microsoft.Resources/deployments', 'aiServices'), '2025-04-01').outputs.aiEndpoint.value), createObject('value', ''))]",
          "webAppDefaultHostName": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'appService'), '2025-04-01').outputs.defaultHostName.value]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
