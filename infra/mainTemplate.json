{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys VariScout Azure App as a Managed Application with App Service and EasyAuth"
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for deployment"
      }
    },
    "appName": {
      "type": "string",
      "defaultValue": "[concat('variscout-', uniqueString(resourceGroup().id))]",
      "minLength": 3,
      "maxLength": 24,
      "metadata": {
        "description": "Name for the App Service (3-24 lowercase letters, numbers, or hyphens)"
      }
    },
    "clientId": {
      "type": "string",
      "metadata": {
        "description": "Client ID of the Azure AD App Registration for authentication"
      }
    },
    "clientSecret": {
      "type": "secureString",
      "metadata": {
        "description": "Client secret of the Azure AD App Registration. TODO: Store in Key Vault and reference via @Microsoft.KeyVault(SecretUri=...) in app settings instead of passing the raw value to MICROSOFT_PROVIDER_AUTHENTICATION_SECRET and Function App CLIENT_SECRET."
      }
    },
    "packageUrl": {
      "type": "string",
      "defaultValue": "https://variscout.blob.core.windows.net/releases/variscout-azure-latest.zip",
      "metadata": {
        "description": "URL to the VariScout application deployment package"
      }
    },
    "variscoutPlan": {
      "type": "string",
      "defaultValue": "standard",
      "allowedValues": ["standard", "team", "team-ai"],
      "metadata": {
        "description": "VariScout plan: 'standard' (local files), 'team' (OneDrive + Teams collaboration), or 'team-ai' (Team features + AI assistance + Knowledge Base)"
      }
    }
  },
  "variables": {
    "appServicePlanName": "[concat(parameters('appName'), '-plan')]",
    "webAppName": "[parameters('appName')]",
    "functionAppName": "[concat(parameters('appName'), '-func')]",
    "functionStorageName": "[concat('vsf', uniqueString(resourceGroup().id))]",
    "functionPlanName": "[concat(parameters('appName'), '-func-plan')]",
    "hasTeamFeatures": "[or(equals(parameters('variscoutPlan'), 'team'), equals(parameters('variscoutPlan'), 'team-ai'))]",
    "isTeamAI": "[equals(parameters('variscoutPlan'), 'team-ai')]",
    "aiServicesName": "[concat(parameters('appName'), '-ai')]",
    "searchServiceName": "[concat(parameters('appName'), '-search')]",
    "aiSearchIndex": "findings"
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "tags": {
        "product": "VariScout",
        "plan": "[parameters('variscoutPlan')]",
        "managedBy": "AzureMarketplace"
      },
      "kind": "linux",
      "sku": {
        "name": "B1",
        "tier": "Basic"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "tags": {
        "product": "VariScout",
        "plan": "[parameters('variscoutPlan')]",
        "managedBy": "AzureMarketplace"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]",
        "[resourceId('Microsoft.Search/searchServices', variables('searchServiceName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "NODE|22-lts",
          "appSettings": [
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "[parameters('packageUrl')]"
            },
            {
              "name": "VITE_LICENSE_TIER",
              "value": "enterprise"
            },
            {
              "name": "MICROSOFT_PROVIDER_AUTHENTICATION_SECRET",
              "value": "[parameters('clientSecret')]"
            },
            {
              "name": "VITE_VARISCOUT_PLAN",
              "value": "[parameters('variscoutPlan')]"
            },
            {
              "name": "VITE_FUNCTION_URL",
              "value": "[if(variables('hasTeamFeatures'), concat('https://', variables('functionAppName'), '.azurewebsites.net'), '')]"
            },
            {
              "name": "AI_ENDPOINT",
              "value": "[if(variables('isTeamAI'), reference(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2025-09-01').endpoint, '')]"
            },
            {
              "name": "AI_SEARCH_ENDPOINT",
              "value": "[if(variables('isTeamAI'), concat('https://', variables('searchServiceName'), '.search.windows.net'), '')]"
            },
            {
              "name": "AI_SEARCH_INDEX",
              "value": "[variables('aiSearchIndex')]"
            },
            {
              "name": "FUNCTION_URL",
              "value": "[if(variables('hasTeamFeatures'), concat('https://', variables('functionAppName'), '.azurewebsites.net'), '')]"
            }
          ],
          "minTlsVersion": "1.2",
          "ftpsState": "Disabled"
        }
      }
    },
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2024-04-01",
      "name": "[concat(variables('webAppName'), '/authsettingsV2')]",
      "dependsOn": ["[resourceId('Microsoft.Web/sites', variables('webAppName'))]"],
      "properties": {
        "platform": {
          "enabled": true
        },
        "globalValidation": {
          "requireAuthentication": true,
          "unauthenticatedClientAction": "RedirectToLoginPage",
          "redirectToProvider": "azureactivedirectory",
          "excludedPaths": ["/health", "/config"]
        },
        "identityProviders": {
          "azureActiveDirectory": {
            "enabled": true,
            "registration": {
              "openIdIssuer": "[concat('https://login.microsoftonline.com/', subscription().tenantId, '/v2.0')]",
              "clientId": "[parameters('clientId')]",
              "clientSecretSettingName": "MICROSOFT_PROVIDER_AUTHENTICATION_SECRET"
            },
            "login": {
              "loginParameters": [
                "[if(variables('hasTeamFeatures'), 'scope=openid profile email User.Read Files.ReadWrite Files.ReadWrite.All Channel.ReadBasic.All People.Read ChannelMessage.Send', 'scope=openid profile email User.Read')]"
              ]
            }
          }
        },
        "login": {
          "tokenStore": {
            "enabled": true
          }
        }
      }
    },
    {
      "condition": "[variables('hasTeamFeatures')]",
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('functionStorageName')]",
      "location": "[parameters('location')]",
      "tags": {
        "product": "VariScout",
        "plan": "[parameters('variscoutPlan')]",
        "managedBy": "AzureMarketplace"
      },
      "kind": "StorageV2",
      "sku": {
        "name": "Standard_LRS"
      },
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2"
      }
    },
    {
      "condition": "[variables('hasTeamFeatures')]",
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2024-04-01",
      "name": "[variables('functionPlanName')]",
      "location": "[parameters('location')]",
      "tags": {
        "product": "VariScout",
        "plan": "[parameters('variscoutPlan')]",
        "managedBy": "AzureMarketplace"
      },
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "properties": {}
    },
    {
      "condition": "[variables('hasTeamFeatures')]",
      "type": "Microsoft.Web/sites",
      "apiVersion": "2024-04-01",
      "name": "[variables('functionAppName')]",
      "location": "[parameters('location')]",
      "tags": {
        "product": "VariScout",
        "plan": "[parameters('variscoutPlan')]",
        "managedBy": "AzureMarketplace"
      },
      "kind": "functionapp",
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('functionPlanName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('functionStorageName'))]",
        "[resourceId('Microsoft.Web/sites', variables('webAppName'))]",
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]",
        "[resourceId('Microsoft.Search/searchServices', variables('searchServiceName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('functionPlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "appSettings": [
            {
              "name": "AzureWebJobsStorage",
              "value": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('functionStorageName'), ';EndpointSuffix=core.windows.net;AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('functionStorageName')), '2023-05-01').keys[0].value)]"
            },
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "node"
            },
            {
              "name": "WEBSITE_NODE_DEFAULT_VERSION",
              "value": "~22"
            },
            {
              "name": "CLIENT_ID",
              "value": "[parameters('clientId')]"
            },
            {
              "name": "CLIENT_SECRET",
              "value": "[parameters('clientSecret')]"
            },
            {
              "name": "TENANT_ID",
              "value": "[subscription().tenantId]"
            },
            {
              "name": "AI_ENDPOINT",
              "value": "[if(variables('isTeamAI'), reference(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2025-09-01').endpoint, '')]"
            },
            {
              "name": "AI_SERVICES_API_KEY",
              "value": "[if(variables('isTeamAI'), listKeys(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2025-09-01').key1, '')]"
            },
            {
              "name": "SEARCH_ENDPOINT",
              "value": "[if(variables('isTeamAI'), concat('https://', variables('searchServiceName'), '.search.windows.net'), '')]"
            },
            {
              "name": "SEARCH_API_KEY",
              "value": "[if(variables('isTeamAI'), listAdminKeys(resourceId('Microsoft.Search/searchServices', variables('searchServiceName')), '2025-05-01').primaryKey, '')]"
            },
            {
              "name": "SEARCH_INDEX",
              "value": "[variables('aiSearchIndex')]"
            }
          ],
          "cors": {
            "allowedOrigins": [
              "[concat('https://', reference(resourceId('Microsoft.Web/sites', variables('webAppName'))).defaultHostName)]"
            ]
          },
          "minTlsVersion": "1.2",
          "ftpsState": "Disabled"
        }
      }
    },
    {
      "condition": "[variables('isTeamAI')]",
      "type": "Microsoft.CognitiveServices/accounts",
      "apiVersion": "2025-09-01",
      "name": "[variables('aiServicesName')]",
      "location": "[parameters('location')]",
      "tags": {
        "product": "VariScout",
        "plan": "[parameters('variscoutPlan')]"
      },
      "identity": { "type": "SystemAssigned" },
      "kind": "OpenAI",
      "sku": { "name": "S0" },
      "properties": {
        "customSubDomainName": "[variables('aiServicesName')]",
        "publicNetworkAccess": "Enabled",
        "networkAcls": { "defaultAction": "Allow" }
      }
    },
    {
      "condition": "[variables('isTeamAI')]",
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2025-09-01",
      "name": "[concat(variables('aiServicesName'), '/fast')]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName'))]"
      ],
      "sku": { "name": "Standard", "capacity": 30 },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "gpt-4o-mini",
          "version": "2024-07-18"
        },
        "versionUpgradeOption": "OnceCurrentVersionExpired"
      }
    },
    {
      "condition": "[variables('isTeamAI')]",
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2025-09-01",
      "name": "[concat(variables('aiServicesName'), '/reasoning')]",
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/deployments', variables('aiServicesName'), 'fast')]"
      ],
      "sku": { "name": "Standard", "capacity": 60 },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "gpt-4o",
          "version": "2024-08-06"
        },
        "versionUpgradeOption": "OnceCurrentVersionExpired"
      }
    },
    {
      "condition": "[variables('isTeamAI')]",
      "type": "Microsoft.Search/searchServices",
      "apiVersion": "2025-05-01",
      "name": "[variables('searchServiceName')]",
      "location": "[parameters('location')]",
      "tags": {
        "product": "VariScout",
        "plan": "[parameters('variscoutPlan')]"
      },
      "identity": { "type": "SystemAssigned" },
      "sku": { "name": "basic" },
      "properties": {
        "replicaCount": 1,
        "partitionCount": 1,
        "hostingMode": "default",
        "semanticSearch": "standard",
        "publicNetworkAccess": "Enabled",
        "authOptions": {
          "aadOrApiKey": {
            "aadAuthFailureMode": "http401WithBearerChallenge"
          }
        },
        "networkRuleSet": {
          "bypass": "AzureServices"
        }
      }
    }
  ],
  "outputs": {
    "appUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.Web/sites', variables('webAppName'))).defaultHostName)]"
    },
    "functionUrl": {
      "condition": "[variables('hasTeamFeatures')]",
      "type": "string",
      "value": "[if(variables('hasTeamFeatures'), concat('https://', variables('functionAppName'), '.azurewebsites.net'), '')]"
    },
    "aiEndpoint": {
      "condition": "[variables('isTeamAI')]",
      "type": "string",
      "value": "[if(variables('isTeamAI'), reference(resourceId('Microsoft.CognitiveServices/accounts', variables('aiServicesName')), '2025-09-01').endpoint, '')]"
    },
    "searchEndpoint": {
      "condition": "[variables('isTeamAI')]",
      "type": "string",
      "value": "[if(variables('isTeamAI'), concat('https://', variables('searchServiceName'), '.search.windows.net'), '')]"
    }
  }
}
