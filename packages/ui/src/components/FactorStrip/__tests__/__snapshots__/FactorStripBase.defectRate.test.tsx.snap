// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`FactorStripBase — defect-rate-share variant > magnitude render path snapshot guard 1`] = `"<div class="relative flex flex-col gap-2 px-3.5 py-2.5"><div class="flex items-baseline gap-2.5 flex-wrap"><h2 class="text-[12.5px] font-semibold text-content">What does explain it?</h2><span class="text-[11px] text-content-muted">how much of the row-to-row differences each factor accounts for (η²) — shares overlap, won't sum to 100%</span><span class="basis-full text-[11px] text-content-muted">Same candidate factors as Frame; ranked here from the data.</span><a href="#" class="ml-auto text-[11px] text-status-info no-underline hover:underline">How these % are computed (model &amp; ANOVA) →</a></div><div class="flex flex-wrap items-stretch gap-1.5"><div data-testid="factor-chip-Team" data-factor="Team" data-weak="false" data-active="false" title="p=0.0003 · df=3,1596 · joint n=1600" aria-label="Team" role="button" tabindex="0" class="flex flex-col gap-1 rounded-lg border px-2.5 py-1.5 cursor-pointer transition-colors border-edge bg-surface-elevated hover:bg-surface-secondary "><span class="flex items-center gap-1.5 text-xs font-semibold text-content"><span>Team</span><span data-testid="factor-chip-star" title="largest share" class="text-status-warning"><svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star fill-status-warning text-status-warning" aria-hidden="true"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg></span></span><span class="flex items-center gap-2"><span data-testid="factor-chip-bar" class="h-1 rounded-full bg-status-info" style="width: 72px;"></span><span class="text-[11px] text-content-secondary">18.0%</span></span></div><div data-testid="factor-chip-residual" title="Residual of the joint model — mostly routine row-to-row variation, plus factors not yet measured. A large residual is typical for service data." class="flex flex-col justify-center px-2.5 py-1.5 text-[11px] text-content-muted">everyday variation · ~82% — not tied to these factors</div></div></div>"`;

exports[`FactorStripBase — defect-rate-share variant > membership render path snapshot guard 1`] = `"<div class="relative flex flex-col gap-2 px-3.5 py-2.5"><div class="flex items-baseline gap-2.5 flex-wrap"><h2 class="text-[12.5px] font-semibold text-content">What distinguishes these rows?</h2><span class="text-[11px] text-content-muted">how strongly each factor distinguishes the rows in this condition from the rest (separation — not % of variation)</span></div><div class="flex flex-wrap items-stretch gap-1.5"><div data-testid="factor-chip-Queue" data-factor="Queue" data-active="false" title="p=0.0010 · χ² df=1 · n=200" aria-label="Queue" role="button" tabindex="0" class="flex flex-col gap-1 rounded-lg border px-2.5 py-1.5 cursor-pointer transition-colors border-edge bg-surface-elevated hover:bg-surface-secondary "><span class="flex items-center gap-1.5 text-xs font-semibold text-content"><span>Queue</span></span><span data-testid="factor-chip-membership-top-level" class="text-[11px] font-medium text-content-secondary">Billing ×3.1</span><span class="flex items-center gap-2"><span data-testid="factor-chip-bar" class="h-1 rounded-full bg-status-info" style="width: 72px;"></span><span data-testid="factor-chip-separation-label" class="text-[11px] text-content-secondary">separation 0.72</span></span></div></div></div>"`;
