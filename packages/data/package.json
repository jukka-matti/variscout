{
  "name": "@variscout/data",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./samples": "./src/samples/index.ts",
    "./computed": "./src/computed/index.ts"
  },
  "dependencies": {
    "@variscout/core": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json --noEmit",
    "generate:computed": "tsx scripts/generate-computed-fixtures.ts",
    "lint": "eslint src --ignore-pattern 'src/**/__tests__/**' --ignore-pattern 'src/**/*.test.ts' --ignore-pattern 'src/**/*.test.tsx' --ignore-pattern 'src/**/*.spec.ts' --ignore-pattern 'src/**/*.spec.tsx'",
    "test": "vitest"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
