{
  "name": "variscout",
  "version": "1.0.0",
  "private": true,
  "description": "VariScout Lite monorepo - PWA and Azure App",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @variscout/pwa dev",
    "build": "turbo build",
    "build:pwa": "pnpm --filter @variscout/pwa build",
    "preview": "pnpm --filter @variscout/pwa preview",
    "test": "turbo test",
    "lint": "turbo lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"apps/*/src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"apps/*/src/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "docs:dev": "pnpm --filter @variscout/docs dev",
    "docs:build": "pnpm --filter @variscout/docs build",
    "docs:preview": "pnpm --filter @variscout/docs preview",
    "docs:check": "bash scripts/check-diagram-health.sh && bash scripts/check-doc-health.sh",
    "docs:check:frontmatter": "node scripts/check-doc-frontmatter.mjs",
    "docs:sync": "bash scripts/sync-monorepo-counts.sh",
    "codex:ruflo-check": "bash scripts/check-codex-ruflo.sh",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check:i18n": "npx tsx scripts/check-i18n.ts"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "eslint-plugin-variscout": "workspace:*",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.3",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.1",
    "turbo": "^2.9.6",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "minimatch@^3.0.0": "3.1.5",
      "minimatch@^10.0.0": "10.2.4",
      "rollup@^4.0.0": "4.59.0",
      "serialize-javascript@^6.0.0": "7.0.3",
      "ajv@^6.0.0": "6.14.0",
      "devalue@^5.0.0": "5.6.4",
      "undici@>=7.0.0": "7.24.0",
      "svgo@^4.0.0": "4.0.1",
      "flatted@^3.0.0": "3.4.2",
      "h3@^1.0.0": "1.15.9",
      "fast-xml-parser@^5.0.0": "5.5.8",
      "picomatch@^2.0.0": "2.3.2",
      "picomatch@>=4.0.0": "4.0.4",
      "handlebars@^4.0.0": "4.7.9",
      "lodash@>=4.0.0": "4.18.1",
      "lodash-es@>=4.0.0": "4.18.1",
      "@xmldom/xmldom@<0.8.12": "0.8.12"
    }
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
